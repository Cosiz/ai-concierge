# ─────────────────────────────────────────────────────────────────
# WhatsApp (Meta) – Webhook & Messaging
# ─────────────────────────────────────────────────────────────────
WHATSAPP_ACCESS_TOKEN=      # Page Access Token from Meta Developer Console
WHATSAPP_PHONE_NUMBER_ID=  # Phone Number ID from Meta App
WHATSAPP_VERIFY_TOKEN=     # Arbitrary random string you choose – must match Meta webhook settings
WHATSAPP_API_VERSION=v21.0  # Meta Graph API version

# ─────────────────────────────────────────────────────────────────
# DashScope (Alibaba) – AI Inference
# ─────────────────────────────────────────────────────────────────
DASHSCOPE_API_KEY=          # From Alibaba DashScope / Model Studio

# ─────────────────────────────────────────────────────────────────
# Supabase
# ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=   # e.g. https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=  # anon/public key (for client reads)
SUPABASE_SERVICE_ROLE_KEY=  # service_role key (server-side only – never expose)
